modules = ["nodejs-20", "python-3.11", "postgresql-16"]

[agent]
expertMode = true
integrations = ["github:1.0.0", "javascript_database:1.0.0"]
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Server"
mode = "sequential"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev --workspace=server"
waitForPort = 8080

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "CHG Rehab"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Deal Link"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Investor Portal"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Contractor Portal"

[[workflows.workflow]]
name = "CHG Rehab"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 npm run dev --workspace=apps/chg-rehab"
waitForPort = 5000

[[workflows.workflow]]
name = "Deal Link"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev --workspace=apps/deallink"
waitForPort = 3001

[[workflows.workflow]]
name = "Investor Portal"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev --workspace=apps/investor-portal"
waitForPort = 3002

[[workflows.workflow]]
name = "Contractor Portal"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev --workspace=apps/contractor-portal"
waitForPort = 3003

[[ports]]
localPort = 3000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 3003
externalPort = 3003

[[ports]]
localPort = 8080
externalPort = 8080

[deployment]
deploymentTarget = "static"
build = ["sh", "-c", "npm install && npm run build --workspace=apps/deallink"]
publicDir = "apps/deallink/dist"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 300000

[userenv]

[userenv.development]
[[deployment.rewrites]]
from = "/*"
to = "/index.html"
