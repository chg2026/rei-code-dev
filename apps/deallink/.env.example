# Deal Link — front-end env vars (Vite)
#
# In dev, these are read by `apps/deallink/src/lib/{supabase,api}.js`. The
# Express API is reached via the Vite proxy in `vite.config.js`
# (`/api → :5000`) so VITE_API_BASE_URL is left blank in dev.
#
# In the Deal Link autoscale deployment (separate from Gold Bridge), set
# these in the deployment's Secrets pane. Vite bakes VITE_* values in at
# build time, so they must be set BEFORE the deploy build runs.

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<supabase-anon-key>

# Cross-origin API base URL. Leave blank in dev (Vite proxy handles /api).
# In prod, point at the Gold Bridge deployment that serves Express, e.g.
#   VITE_API_BASE_URL=https://app.goldbridge.dev
# The CRM Express server has permissive CORS and uses Bearer-token auth, so
# cross-origin calls from the Deal Link SPA work without cookie plumbing.
VITE_API_BASE_URL=

# Optional: override the API host the Vite dev proxy forwards to. Defaults
# to http://localhost:8080 (the Gold Bridge Express server).
DEALLINK_API_PORT=8080
