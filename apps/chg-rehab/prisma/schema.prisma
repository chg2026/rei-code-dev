generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  sid    String   @id
  sess   Json
  expire DateTime

  @@index([expire])
  @@map("sessions")
}

model Company {
  id                   String                @id @default(cuid())
  name                 String
  legalName            String?
  ein                  String?
  createdAt            DateTime              @default(now())
  activityLog          ActivityLogEntry[]
  settings             CompanySetting?
  contacts             Contact[]
  documents            Document[]
  leases               Lease[]
  permissionLabels     PermissionLabelRow[]
  permissionRows       PermissionMatrixRow[]
  pipelineDeals        PipelineDeal[]
  projects             Project[]
  properties           Property[]
  users                User[]
  warehouseDepartments WarehouseDepartment[]
  warehouseTemplates   WarehouseTemplate[]
  invites              Invite[]
  subscription         Subscription?
  notifications        Notification[]
  notificationState    NotificationState?
  contactNotifications ContactNotificationLog[]
  staleSweepAlerts     StaleSweepAlertLog[]
  investors            Investor[]
  offerings            Offering[]
  investorDocuments    InvestorDocument[]
}

model User {
  id                       String                        @id
  companyId                String
  email                    String?                       @unique
  firstName                String?
  lastName                 String?
  profileImageUrl          String?
  role                     UserRole                      @default(ProjectManager)
  initials                 String?
  emailOptOut              Boolean                       @default(false)
  active                   Boolean                       @default(true)
  deactivatedAt            DateTime?
  notifyQuietStart         String?
  notifyQuietEnd           String?
  notifyQuietOverride      Boolean                       @default(false)
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @default(now()) @updatedAt
  activityEntries          ActivityLogEntry[]
  uploadedDocuments        Document[]                    @relation("DocUploader")
  approvedDraws            Draw[]                        @relation("DrawApprover")
  projectAssignments       ProjectAssignment[]
  notifications            Notification[]
  notificationPreferences  UserNotificationPreference[]
  company                  Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, active])
}

model UserNotificationPreference {
  id        String   @id @default(cuid())
  userId    String
  event     String
  email     Boolean
  inApp     Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, event])
  @@index([userId])
}

model Property {
  id            String                     @id @default(cuid())
  companyId     String
  code          String
  address       String
  city          String?
  state         String?
  zip           String?
  status        String?
  acquired      DateTime?
  baseline      Decimal?                   @db.Decimal(14, 2)
  currentRoi    Decimal?                   @db.Decimal(6, 2)
  meta          Json?
  createdAt     DateTime                   @default(now())
  documents     Document[]
  leases        Lease[]
  pipelineDeals PipelineDeal[]
  projects      Project[]
  company       Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assets        PropertyAsset[]
  financials    PropertyFinancialSection[]
  offerings     Offering[]

  @@unique([companyId, code])
  @@index([companyId])
}

model PropertyAsset {
  id          String    @id @default(cuid())
  propertyId  String
  category    String
  name        String
  installed   DateTime?
  warrantyEnd DateTime?
  notes       String?
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model PropertyFinancialSection {
  id         String   @id @default(cuid())
  propertyId String
  section    String
  data       Json
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, section])
}

model PipelineDeal {
  id           String    @id @default(cuid())
  companyId    String
  propertyId   String?
  code         String
  address      String
  askingPrice  Decimal?  @db.Decimal(14, 2)
  estimatedRoi Decimal?  @db.Decimal(6, 2)
  stage        DealStage @default(Sourced)
  notes        String?
  meta         Json?
  closedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  property     Property? @relation(fields: [propertyId], references: [id])

  @@index([companyId, stage])
}

model Project {
  id                    String                 @id @default(cuid())
  companyId             String
  propertyId            String
  code                  String                 // 'CHG-2247'
  name                  String
  status                ProjectStatus          @default(Planning)
  budget                Decimal?               @db.Decimal(14, 2)
  startDate             DateTime?
  endDate               DateTime?
  currentPhase          Int?
  meta                  Json?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @default(now()) @updatedAt

  company               Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  property              Property               @relation(fields: [propertyId], references: [id])
  phases                Phase[]
  draws                 Draw[]
  sowSections           SOWSection[]
  addenda               ProjectAddendum[]
  assignments           ProjectAssignment[]
  contractorAssignments ContractorAssignment[]
  documents             Document[]
  warehouseAllocations  WarehouseItem[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Phase {
  id             String          @id @default(cuid())
  projectId      String
  number         Int
  name           String
  status         PhaseStatus     @default(NotStarted)
  budget         Decimal?        @db.Decimal(14, 2)
  actual         Decimal?        @db.Decimal(14, 2)
  startDate      DateTime?
  endDate        DateTime?
  drawNote       String?
  checklistItems ChecklistItem[]
  draws          Draw[]
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([projectId])
}

model ChecklistItem {
  id        String          @id @default(cuid())
  phaseId   String
  label     String
  status    ChecklistStatus @default(Pending)
  meta      Json?
  doneBy    String?
  doneAt    DateTime?
  createdAt DateTime        @default(now())
  phase     Phase           @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  @@index([phaseId])
}

model Draw {
  id           String     @id @default(cuid())
  projectId    String
  phaseId      String?
  number       Int
  title        String
  amount       Decimal    @db.Decimal(14, 2)
  status       DrawStatus @default(Pending)
  approvedAt   DateTime?
  approvedById String?
  paidAt       DateTime?
  notes        String?
  createdAt    DateTime   @default(now())
  approvedBy   User?      @relation("DrawApprover", fields: [approvedById], references: [id])
  phase        Phase?     @relation(fields: [phaseId], references: [id])
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model SOWSection {
  id        String        @id @default(cuid())
  projectId String
  name      String
  order     Int           @default(0)
  lineItems SOWLineItem[]
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model SOWLineItem {
  id          String     @id @default(cuid())
  sectionId   String
  description String
  qty         Decimal?   @db.Decimal(10, 2)
  unit        String?
  unitCost    Decimal?   @db.Decimal(14, 2)
  totalCost   Decimal?   @db.Decimal(14, 2)
  notes       String?
  section     SOWSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
}

model ProjectAddendum {
  id        String   @id @default(cuid())
  projectId String
  title     String
  reason    String?
  delta     Decimal? @db.Decimal(14, 2)
  daysDelta Int      @default(0)
  status    String   @default("Pending")
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectAssignment {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  role      String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId, role])
  @@index([userId])
}

model Contact {
  id             String                    @id @default(cuid())
  companyId      String
  type           ContactType
  name           String
  company        String?
  email          String?
  phone          String?
  address        String?
  trade          String?
  rating         Int?
  notes          String?
  meta           Json?
  emailOptOut    Boolean                   @default(false)
  emailOptOutAt  DateTime?
  createdAt      DateTime                  @default(now())

  org            Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  complianceDocs ContractorComplianceDoc[]
  assignments    ContractorAssignment[]
  notificationLogs ContactNotificationLog[]

  @@index([companyId, type])
}

// A persistent assignment of a Contact (typically Contractor / Subcontractor)
// to a Project for a given role. We model this separately from
// `ProjectAssignment` because that table links users (employees) to projects,
// whereas contractors live in `Contact` and are external.
model ContractorAssignment {
  id          String   @id @default(cuid())
  companyId   String
  contactId   String
  projectId   String
  role        String   // e.g. "GC", "Electrical sub"
  status      String   @default("Active") // Active | Completed | Removed
  assignedAt  DateTime @default(now())
  assignedBy  String?

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, contactId, role])
  @@index([companyId])
  @@index([contactId])
  @@index([projectId])
}

model ContractorComplianceDoc {
  id        String    @id @default(cuid())
  contactId String
  type      String
  name      String
  expiresAt DateTime?
  fileKey   String?
  status    String    @default("Active")
  createdAt DateTime  @default(now())
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  versions  ContractorComplianceDocVersion[]

  @@index([contactId])
}

model ContractorComplianceDocVersion {
  id         String    @id @default(cuid())
  docId      String
  name       String
  expiresAt  DateTime?
  fileKey    String?
  replacedAt DateTime  @default(now())
  doc        ContractorComplianceDoc @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@index([docId])
}

model Lease {
  id         String    @id @default(cuid())
  companyId  String
  propertyId String
  tenantName String
  rent       Decimal?  @db.Decimal(10, 2)
  startDate  DateTime?
  endDate    DateTime?
  status     String    @default("Active")
  meta       Json?
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model WarehouseDepartment {
  id            String                 @id @default(cuid())
  companyId     String
  code          String
  name          String
  icon          String?
  order         Int                    @default(0)
  pinned        Boolean                @default(false)
  hidden        Boolean                @default(false)
  company       Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subcategories WarehouseSubcategory[]

  @@unique([companyId, code])
  @@index([companyId])
}

model WarehouseSubcategory {
  id           String              @id @default(cuid())
  departmentId String
  code         String
  name         String
  order        Int                 @default(0)
  pinned       Boolean             @default(false)
  hidden       Boolean             @default(false)
  items        WarehouseItem[]
  department   WarehouseDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([departmentId, code])
}

model WarehouseItem {
  id            String               @id @default(cuid())
  subcategoryId String
  name          String
  brand         String?
  model         String?
  unit          String?
  defaultCost   Decimal?             @db.Decimal(14, 2)
  vendor        String?
  notes         String?
  meta          Json?
  qty           Decimal?             @db.Decimal(12, 2)
  condition     String?
  value         Decimal?             @db.Decimal(14, 2)
  projectId     String?
  project       Project?             @relation(fields: [projectId], references: [id])
  subcategory   WarehouseSubcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)

  @@index([subcategoryId])
  @@index([projectId])
}

model WarehouseTemplate {
  id        String   @id @default(cuid())
  companyId String
  name      String
  scope     String?
  data      Json
  isDefault Boolean  @default(false)
  isLocked  Boolean  @default(false)
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Document {
  id           String    @id @default(cuid())
  companyId    String
  level        DocLevel
  category     String
  status       DocStatus @default(Active)
  name         String
  fileKey      String?
  mimeType     String?
  size         Int?
  expiresAt    DateTime?
  uploadedById String?
  uploadedAt   DateTime  @default(now())
  propertyId   String?
  projectId    String?
  contactId    String?
  meta         Json?
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project      Project?  @relation(fields: [projectId], references: [id])
  property     Property? @relation(fields: [propertyId], references: [id])
  uploadedBy   User?     @relation("DocUploader", fields: [uploadedById], references: [id])

  @@index([companyId, level])
}

model ActivityLogEntry {
  id        String   @id @default(cuid())
  companyId String
  actorId   String?
  action    String
  entity    String?
  entityId  String?
  message   String?
  meta      Json?
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
}

model PermissionMatrixRow {
  id        String  @id @default(cuid())
  companyId String
  feature   String
  action    String
  roles     Json
  notes     String?
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, feature, action])
}

model PermissionLabelRow {
  id        String  @id @default(cuid())
  companyId String
  label     String
  ord       Int     @default(0)
  pm        String  @default("none")
  gc        String  @default("none")
  sub       String  @default("none")
  inspector String  @default("none")
  adminLock Boolean @default(false)
  locked    Boolean @default(false)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, label])
}

model Invite {
  id           String    @id @default(cuid())
  companyId    String
  email        String
  role         UserRole
  token        String    @unique
  status       String    @default("Pending") // Pending | Accepted | Revoked | Expired
  invitedById  String?
  acceptedById String?
  expiresAt    DateTime
  acceptedAt   DateTime?
  createdAt    DateTime  @default(now())
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([email])
}

model Subscription {
  id                       String    @id @default(cuid())
  companyId                String    @unique
  plan                     String    @default("Operator") // Starter | Operator | Enterprise
  status                   String    @default("inactive") // active | trialing | past_due | canceled | inactive | incomplete
  seatLimit                Int       @default(25)
  stripeCustomerId         String?
  stripeSubscriptionId     String?
  stripePriceId            String?
  stripeProductId          String?
  currentPeriodEnd         DateTime?
  cancelAtPeriodEnd        Boolean   @default(false)
  defaultPaymentMethodId   String?
  paymentMethodBrand       String?
  paymentMethodLast4       String?
  paymentMethodExpMonth    Int?
  paymentMethodExpYear     Int?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @default(now()) @updatedAt
  company                  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model CompanySetting {
  id                           String  @id @default(cuid())
  companyId                    String  @unique
  strictGate                   Boolean @default(true)
  coiThresholdDays             Int     @default(60)
  strictPaymentGate            Boolean @default(true)
  blockAssignmentIfDocsMissing Boolean @default(true)
  expiryAlertThresholdDays     Int     @default(60)
  companyName                  String?
  projectIdPrefix              String  @default("CHG-")
  defaultProjectMode           String  @default("Contractor-Led")
  timezone                     String  @default("America/New_York")
  dateFormat                   String  @default("MM/DD/YYYY")
  currency                     String  @default("USD")
  fiscalYearStart              String  @default("January")
  warehouseLowStockThreshold   Int     @default(5)
  warehouseValueRoundingMode   String  @default("nearest")
  contractorPortalEnabled      Boolean @default(false)
  meta                         Json?
  company                      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

enum UserRole {
  Admin
  ProjectManager
  GeneralContractor
  Subcontractor
  Inspector
  Tenant
  Vendor
}

enum DealStage {
  Sourced
  Underwriting
  OfferOut
  UnderContract
  Closed
  Lost
}

enum ProjectStatus {
  Planning
  Active
  OnHold
  Complete
}

enum PhaseStatus {
  NotStarted
  Active
  Complete
  OnHold
}

enum ChecklistStatus {
  Pending
  Done
  Flagged
  NA
}

enum DrawStatus {
  Pending
  Approved
  Paid
  Rejected
}

enum ContactType {
  Contractor
  Subcontractor
  Vendor
  Inspector
  Tenant
  Other
}

enum DocLevel {
  Company
  Property
  Project
  Contact
}

enum DocStatus {
  Active
  Expired
  Pending
  Archived
  Staged
}

model Notification {
  id            String    @id @default(cuid())
  companyId     String
  userId        String
  event         String
  channel       String
  title         String
  body          String?
  link          String?
  meta          Json?
  status        String    @default("Pending")
  urgent        Boolean   @default(false)
  scheduledFor  DateTime?
  sentAt        DateTime?
  failedAt      DateTime?
  failureReason String?
  resolvedAt    DateTime?
  resolvedById  String?
  resolvedReason String?
  readAt        DateTime?
  dedupeKey     String?
  createdAt     DateTime  @default(now())

  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, userId, channel, readAt])
  @@index([companyId, channel, status, scheduledFor])
  @@index([companyId, channel, status, failedAt])
  @@index([companyId, channel, status, resolvedAt])
  @@unique([userId, channel, dedupeKey])
}

model NotificationState {
  id                       String    @id @default(cuid())
  companyId                String    @unique
  lastDigestSweepAt        DateTime?
  lastSweepAttemptAt       DateTime?
  lastLapseSweepAt         DateTime?
  lastStaleAlertAt         DateTime?
  lastWeeklyAlertRecapAt   DateTime?
  lastManualSweepAt        DateTime?
  lastManualSweepByUserId  String?
  lastManualSweepByName    String?
  updatedAt                DateTime  @default(now()) @updatedAt

  company                  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model StaleSweepAlertLog {
  id              String   @id @default(cuid())
  companyId       String
  sentAt          DateTime @default(now())
  staleForMs      Float?
  thresholdMs     Int
  throttleMs      Int
  recipientCount  Int
  deliveredCount  Int
  failedCount     Int
  recipients      Json
  createdAt       DateTime @default(now())

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, sentAt])
}

model ContactNotificationLog {
  id             String    @id @default(cuid())
  companyId      String
  contactId      String
  event          String
  dedupeKey      String
  status         String    @default("Sent") // "Sent" | "Failed"
  title          String?
  link           String?
  recipientEmail String?
  failureReason  String?
  failedAt       DateTime?
  resolvedAt     DateTime?
  resolvedById   String?
  resolvedReason String?
  sentAt         DateTime  @default(now())

  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact        Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, event, dedupeKey])
  @@index([companyId, contactId])
  @@index([companyId, status, failedAt])
  @@index([companyId, status, resolvedAt])
}

// ─────────────────────────────────────────────────────────────────────────
// Investor Portal (apps/investor-portal) — added in Investor Portal Phase 1.
// Mirrors chg-rehab `User`/`Subscription` patterns: a Supabase-mirrored
// identity table (`Investor`) per Operator `Company`, plus the deal/cap
// table data the portal renders (offerings, subscriptions, capital calls,
// distributions, documents, updates, activity feed, CRM communications).
// ─────────────────────────────────────────────────────────────────────────

model Investor {
  id                  String                          @id // Supabase auth uid
  companyId           String
  email               String?                         @unique
  firstName           String?
  lastName            String?
  phone               String?
  accreditedStatus    InvestorAccreditedStatus        @default(Unverified)
  status              InvestorStatus                  @default(Lead)
  portalLastLoginAt   DateTime?
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @default(now()) @updatedAt

  company             Company                         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscriptions       InvestorSubscription[]
  documents           InvestorDocument[]
  activities          InvestorActivity[]
  communications      InvestorCommunication[]
  notes               InvestorNote[]
  notificationPrefs   InvestorNotificationPreference[]

  @@index([companyId, status])
}

model Offering {
  id              String                @id @default(cuid())
  companyId       String
  propertyId      String?
  name            String
  propertyType    OfferingPropertyType  @default(Other)
  marketCity      String?
  marketState     String?
  description     String?
  targetIrrLow    Decimal?              @db.Decimal(6, 2)
  targetIrrHigh   Decimal?              @db.Decimal(6, 2)
  prefReturnPct   Decimal?              @db.Decimal(6, 2)
  holdMonths      Int?
  minInvestment   Decimal?              @db.Decimal(14, 2)
  raiseTarget     Decimal?              @db.Decimal(14, 2)
  raisedToHard    Decimal?              @db.Decimal(14, 2)
  raisedToSoft    Decimal?              @db.Decimal(14, 2)
  closeDate       DateTime?
  stage           OfferingStage         @default(Prospecting)
  status          OfferingStatus        @default(Active)
  coverImageUrl   String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @default(now()) @updatedAt

  company         Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  property        Property?             @relation(fields: [propertyId], references: [id])
  subscriptions   InvestorSubscription[]
  capitalCalls    CapitalCall[]
  distributions   Distribution[]
  documents       InvestorDocument[]
  updates         DealUpdate[]

  @@index([companyId, status])
  @@index([companyId, stage])
}

// Investor↔Offering subscription (cap-table row). Named `InvestorSubscription`
// because chg-rehab already owns a `Subscription` model for Stripe billing.
model InvestorSubscription {
  id                    String                       @id @default(cuid())
  investorId            String
  offeringId            String
  committedAmount       Decimal                      @db.Decimal(14, 2)
  fundedAmount          Decimal                      @default(0) @db.Decimal(14, 2)
  commitmentType        SubscriptionCommitmentType   @default(Soft)
  signedAt              DateTime?
  fundedAt              DateTime?
  ownershipPct          Decimal?                     @db.Decimal(8, 4)
  currentValue          Decimal?                     @db.Decimal(14, 2)
  lifetimeDistributions Decimal                      @default(0) @db.Decimal(14, 2)
  irrToDate             Decimal?                     @db.Decimal(6, 2)
  cocToDate             Decimal?                     @db.Decimal(6, 2)
  status                InvestorSubscriptionStatus   @default(Pending)
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @default(now()) @updatedAt

  investor              Investor                     @relation(fields: [investorId], references: [id], onDelete: Cascade)
  offering              Offering                     @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  callAllocations       CapitalCallAllocation[]
  distributionAllocations DistributionAllocation[]

  @@unique([investorId, offeringId])
  @@index([offeringId, status])
}

model CapitalCall {
  id            String                  @id @default(cuid())
  offeringId    String
  noticeNumber  String
  totalAmount   Decimal                 @db.Decimal(14, 2)
  dueDate       DateTime?
  status        CapitalCallStatus       @default(Draft)
  issuedAt      DateTime?
  memo          String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @default(now()) @updatedAt

  offering      Offering                @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  allocations   CapitalCallAllocation[]

  @@unique([offeringId, noticeNumber])
  @@index([offeringId, status])
}

model CapitalCallAllocation {
  id              String     @id @default(cuid())
  capitalCallId   String
  subscriptionId  String
  amountDue       Decimal    @db.Decimal(14, 2)
  amountReceived  Decimal    @default(0) @db.Decimal(14, 2)
  receivedAt      DateTime?

  capitalCall     CapitalCall          @relation(fields: [capitalCallId], references: [id], onDelete: Cascade)
  subscription    InvestorSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([capitalCallId, subscriptionId])
  @@index([subscriptionId])
}

model Distribution {
  id              String                  @id @default(cuid())
  offeringId      String
  periodLabel     String
  distributionType DistributionType       @default(CashFlow)
  totalAmount     Decimal                 @db.Decimal(14, 2)
  perDollarRate   Decimal?                @db.Decimal(10, 6)
  paidOn          DateTime?
  status          DistributionStatus      @default(Pending)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @default(now()) @updatedAt

  offering        Offering                @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  allocations     DistributionAllocation[]

  @@index([offeringId, status])
}

model DistributionAllocation {
  id              String                       @id @default(cuid())
  distributionId  String
  subscriptionId  String
  amount          Decimal                      @db.Decimal(14, 2)
  wireRef         String?
  status          DistributionAllocationStatus @default(Pending)

  distribution    Distribution         @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  subscription    InvestorSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([distributionId, subscriptionId])
  @@index([subscriptionId])
}

model InvestorDocument {
  id            String                  @id @default(cuid())
  companyId     String
  investorId    String?
  offeringId    String?
  name          String
  docType       InvestorDocType         @default(Other)
  objectPath    String?
  sizeBytes     Int?
  uploadedById  String?
  uploadedAt    DateTime                @default(now())
  taxYear       Int?

  company       Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  investor      Investor?               @relation(fields: [investorId], references: [id], onDelete: Cascade)
  offering      Offering?               @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  activities    InvestorActivity[]

  @@index([investorId])
  @@index([offeringId, docType])
  @@index([companyId])
}

model DealUpdate {
  id            String                @id @default(cuid())
  offeringId    String
  updateType    DealUpdateType        @default(Quarterly)
  title         String
  body          String?
  metricsJson   Json?
  postedById    String?
  postedAt      DateTime              @default(now())
  published     Boolean               @default(false)

  offering      Offering              @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  activities    InvestorActivity[]

  @@index([offeringId, postedAt])
}

model InvestorActivity {
  id                    String                  @id @default(cuid())
  investorId            String
  eventType             InvestorActivityType    @default(Other)
  title                 String
  description           String?
  relatedSubscriptionId String?
  relatedDocumentId     String?
  relatedUpdateId       String?
  createdAt             DateTime                @default(now())

  investor              Investor                @relation(fields: [investorId], references: [id], onDelete: Cascade)
  relatedDocument       InvestorDocument?       @relation(fields: [relatedDocumentId], references: [id])
  relatedUpdate         DealUpdate?             @relation(fields: [relatedUpdateId], references: [id])

  @@index([investorId, createdAt])
}

model InvestorCommunication {
  id           String                       @id @default(cuid())
  investorId   String
  channel      InvestorCommunicationChannel @default(Note)
  subject      String?
  body         String?
  durationMin  Int?
  loggedById   String?
  loggedAt     DateTime                     @default(now())

  investor     Investor                     @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([investorId, loggedAt])
}

model InvestorNote {
  id          String    @id @default(cuid())
  investorId  String
  body        String
  authorId    String?
  createdAt   DateTime  @default(now())

  investor    Investor  @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([investorId])
}

model InvestorNotificationPreference {
  id          String    @id @default(cuid())
  investorId  String
  event       String    // distribution | document | update | newdeal | captable
  email       Boolean   @default(true)
  inApp       Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  investor    Investor  @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@unique([investorId, event])
  @@index([investorId])
}

enum InvestorAccreditedStatus {
  Unverified
  Self
  Verified
}

enum InvestorStatus {
  Lead
  Prospect
  Active
  Inactive
}

enum OfferingPropertyType {
  MF
  SF
  MX
  Other
}

enum OfferingStage {
  Prospecting
  Diligence
  Raise
  Closing
  Closed
}

enum OfferingStatus {
  Active
  Archived
}

enum SubscriptionCommitmentType {
  Soft
  Hard
}

enum InvestorSubscriptionStatus {
  Pending
  Active
  Closed
}

enum CapitalCallStatus {
  Draft
  Issued
  Funded
  Cancelled
}

enum DistributionType {
  CashFlow
  ReturnOfCapital
  Sale
}

enum DistributionStatus {
  Pending
  Sent
}

enum DistributionAllocationStatus {
  Pending
  Sent
  Failed
}

enum InvestorDocType {
  PPM
  Agreement
  Statement
  TaxK1
  Update
  Other
}

enum DealUpdateType {
  Quarterly
  Leasing
  Annual
  Distribution
  Market
}

enum InvestorActivityType {
  Distribution
  Document
  Update
  CapitalCall
  Subscription
  Other
}

enum InvestorCommunicationChannel {
  Email
  Phone
  Note
  Meeting
}
