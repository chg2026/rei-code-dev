// ========================================================================
// Workspace module (Command Center + Messages) — added Task #1.
// Domain data for the operator-facing workspace lives in Replit Postgres
// via Prisma. Notifications reuse the existing Notification table with
// channel="inApp" and event values prefixed with "workspace.*".
// ========================================================================

model WsTask {
  id              String    @id @default(cuid())
  companyId       String
  createdById     String
  assigneeId      String?
  title           String
  description     String?
  priority        String    @default("Medium") // Urgent | Medium | Low
  dueDate         DateTime?
  done            Boolean   @default(false)
  doneAt          DateTime?
  linkType        String? // "deal" | "project"
  linkId          String?
  linkLabel       String? // denormalised display label e.g. "210 Harbour Ln (Rehab)"
  sourceMessageId String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy     User            @relation("WsTaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  assignee      User?           @relation("WsTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  sourceMessage WsMessage?      @relation("WsMessageConvertedTask", fields: [sourceMessageId], references: [id], onDelete: SetNull)
  comments      WsTaskComment[]
  attachments   WsTaskAttachment[]
  parentTaskId  String?
  parentTask    WsTask?            @relation("WsSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks      WsTask[]           @relation("WsSubtasks")
  activity      WsTaskActivity[]

  @@index([companyId, done, dueDate])
  @@index([companyId, assigneeId, done])
  @@index([companyId, createdById, done])
  @@index([parentTaskId])
}

model WsTaskActivity {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  action    String
  detail    String?
  createdAt DateTime @default(now())

  task WsTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User   @relation("WsTaskActivityUser", fields: [userId], references: [id])

  @@index([taskId])
}

model WsTaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  task   WsTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User   @relation("WsTaskCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model WsTaskAttachment {
  id           String   @id @default(cuid())
  taskId       String
  uploadedById String
  name         String
  objectPath   String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())

  task       WsTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation("WsTaskAttachmentUploader", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model WsChannel {
  id        String   @id @default(cuid())
  companyId String
  kind      String // "team" | "contractor" | "investor"
  slug      String? // for team channels: "general", "acquisitions", etc.
  name      String
  partyType String? // "CpAccount" | "Investor"
  partyId   String? // CpAccount.id or Investor.id for DM channels
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  members  WsChannelMember[]
  messages WsMessage[]

  @@unique([companyId, kind, slug])
  @@unique([companyId, kind, partyType, partyId])
  @@index([companyId, kind])
}

model WsChannelMember {
  id         String    @id @default(cuid())
  channelId  String
  userId     String
  lastReadAt DateTime?
  createdAt  DateTime  @default(now())

  channel WsChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model WsMessage {
  id              String   @id @default(cuid())
  companyId       String
  channelId       String
  authorUserId    String? // null = system message
  authorLabel     String? // for system or external party messages
  body            String
  convertedTaskId String? // populated when a task is created from this message
  createdAt       DateTime @default(now())

  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  channel       WsChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author        User?     @relation("WsMessageAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  convertedTask WsTask?   @relation("WsMessageConvertedTask")

  @@index([channelId, createdAt])
  @@index([companyId, createdAt])
}

model WsGoal {
  id          String   @id @default(cuid())
  companyId   String
  ownerUserId String? // null = company-wide goal
  title       String
  scope       String   @default("company") // "company" | "user"
  period      String? // e.g. "2026-Q2"
  metricMode  String   @default("count") // "count" | "percent"
  current     Int      @default(0)
  target      Int      @default(1)
  done        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner   User?   @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([companyId, scope])
  @@index([companyId, ownerUserId])
}

model WsReminder {
  id        String    @id @default(cuid())
  companyId String
  userId    String? // null = company-wide
  title     String
  source    String? // breadcrumb e.g. "Documents hub · Insurance & COI"
  link      String?
  remindAt  DateTime?
  urgent    Boolean   @default(false)
  done      Boolean   @default(false)
  doneAt    DateTime?
  createdAt DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, done, remindAt])
  @@index([companyId, userId, done])
}

model WsCalendarEvent {
  id          String    @id @default(cuid())
  companyId   String
  createdById String?
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime?
  link        String?
  createdAt   DateTime  @default(now())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([companyId, startAt])
}

model PmSpace {
  id        String     @id @default(cuid())
  companyId String
  name      String
  color     String?
  icon      String?
  order     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now()) @updatedAt
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lists     PmList[]
  statuses  PmStatus[]
  tags      PmTag[]

  @@index([companyId])
}

model PmList {
  id        String     @id @default(cuid())
  companyId String
  spaceId   String
  name      String
  color     String?
  order     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now()) @updatedAt
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  space     PmSpace    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  tasks     PmTask[]
  statuses  PmStatus[]

  @@index([companyId])
  @@index([spaceId])
}

model PmStatus {
  id        String   @id @default(cuid())
  companyId String
  spaceId   String?
  listId    String?
  name      String
  color     String   @default("#6B7280")
  type      String   @default("open")
  order     Int      @default(0)
  isDefault Boolean  @default(false)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  space     PmSpace? @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  list      PmList?  @relation(fields: [listId], references: [id], onDelete: Cascade)
  tasks     PmTask[]

  @@index([companyId])
}

model PmTag {
  id        String      @id @default(cuid())
  companyId String
  spaceId   String
  name      String
  color     String      @default("#E5E7EB")
  textColor String      @default("#374151")
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  space     PmSpace     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  tasks     PmTaskTag[]

  @@index([companyId])
}

model PmTask {
  id           String           @id @default(cuid())
  companyId    String
  listId       String
  parentTaskId String?
  createdById  String
  name         String
  description  String?
  taskType     String           @default("task")
  statusId     String?
  priority     String?
  coverImage   String?
  startDate    DateTime?
  dueDate      DateTime?
  closedDate   DateTime?
  doneDate     DateTime?
  timeEstimate Int?
  sprintPoints Int?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @default(now()) @updatedAt
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  list         PmList           @relation(fields: [listId], references: [id], onDelete: Cascade)
  status       PmStatus?        @relation(fields: [statusId], references: [id], onDelete: SetNull)
  createdBy    User             @relation("PmTaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  parent       PmTask?          @relation("PmSubtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks     PmTask[]         @relation("PmSubtasks")
  assignees    PmTaskAssignee[]
  tags         PmTaskTag[]
  comments     PmComment[]
  activity     PmActivity[]
  attachments  PmTaskAttachment[]

  @@index([companyId])
  @@index([listId])
  @@index([parentTaskId])
}

model PmTaskAttachment {
  id           String   @id @default(cuid())
  taskId       String
  uploadedById String
  name         String
  objectPath   String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())

  task       PmTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation("PmTaskAttachmentUploader", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model PmTaskAssignee {
  taskId String
  userId String
  task   PmTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation("PmAssignments", fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

model PmTaskTag {
  taskId String
  tagId  String
  task   PmTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag    PmTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model PmComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  body      String
  isEdited  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  task      PmTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User     @relation("PmComments", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model PmActivity {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  type      String
  payload   Json?
  createdAt DateTime @default(now())
  task      PmTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation("PmActivityLog", fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Invoice {
  id             String                @id @default(cuid())
  projectId      String
  phaseId        String?
  vendor         String
  invoiceNumber  String?
  date           DateTime              @db.Date
  amount         Decimal               @db.Decimal(14, 2)
  classification InvoiceClassification @default(Other)
  status         InvoiceStatus         @default(Unpaid)
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  project        Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  attachments    InvoiceAttachment[]

  @@index([projectId])
}

model InvoiceAttachment {
  id         String   @id @default(cuid())
  invoiceId  String
  name       String
  objectPath String
  mimeType   String   @default("application/octet-stream")
  size       Int      @default(0)
  createdAt  DateTime @default(now())
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

enum InvoiceClassification {
  Labor
  Materials
  Permit
  Dumpster
  Utility
  Other
}

enum InvoiceStatus {
  Unpaid
  Pending
  Paid
}

model ChangeOrder {
  id           String            @id @default(cuid())
  projectId    String
  phaseId      String?
  number       Int
  title        String
  reason       String?
  amount       Decimal           @db.Decimal(14, 2)
  status       ChangeOrderStatus @default(Pending)
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([projectId])
}

enum ChangeOrderStatus {
  Pending
  Approved
  Rejected
}
