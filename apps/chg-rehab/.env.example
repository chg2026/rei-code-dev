# CHG Rehab (apps/chg-rehab) — environment surface
#
# DO NOT COMMIT a real .env file. This file is the schema only.
# Use the Replit "Secrets" panel to set these in the dev environment, and
# the deployment-level secrets pane for the CHG Rehab autoscale deployment.
#
# The list is generated from the source — every NAME below is referenced by
# `process.env.NAME` somewhere in apps/chg-rehab/{lib,app,scripts,middleware,instrumentation}.
# See apps/chg-rehab/replit.md for what each block does.

# ── Database (Prisma → PostgreSQL) ────────────────────────────────────────
# DATABASE_URL is auto-provided by the Replit `postgresql-16` module declared
# in the root .replit. Override only if you point at an external Postgres.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# ── Iron-session (cookie auth) ────────────────────────────────────────────
# Min 32 chars, random. Used to sign the `chg_session` cookie.
SESSION_SECRET=replace-me-with-a-32-byte-random-string

# ── Supabase auth (login flow) ────────────────────────────────────────────
# Shared with the Gold Bridge Express server. CHG Rehab trusts auth.uid() as the Prisma
# User.id (shadow-sync) and reads `user_profiles` + `accounts` via the
# service-role key on first sign-in.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# REPLIT_DOMAINS, and REPLIT_DEV_DOMAIN are auto-provided by Replit at
# runtime — leave blank locally. REPLIT_DEV_DOMAIN is used as a fallback
# unsubscribe-link host in lib/contactUnsubscribe.ts when REPLIT_DOMAINS
# is empty.
REPLIT_DOMAINS=
REPLIT_DEV_DOMAIN=
APP_BASE_URL=
NEXT_PUBLIC_APP_URL=

# ── App switcher: production URLs for sibling apps ───────────────────────────
# When CHG Rehab is deployed to production (non-.replit.dev domain), the app
# switcher cannot auto-derive sibling app URLs from the hostname. Set these to
# the deployed URLs of each Gold Bridge app so the tiles remain clickable.
# Leave blank in dev — the Replit preview-port heuristic handles it automatically.
NEXT_PUBLIC_DEALLINK_URL=
NEXT_PUBLIC_CHG_URL=
NEXT_PUBLIC_INVESTOR_URL=
NEXT_PUBLIC_CONTRACTOR_URL=

# NODE_ENV and NEXT_RUNTIME are set by Next.js / Node automatically
# (informational only — do not set these by hand).

# ── Stripe (billing) ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Optional: Google Maps JavaScript API key (Places library) for US-only address
# autocomplete on the Add Property form. When unset, the address fields fall back
# to plain text inputs.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_OPERATOR=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Email (Resend HTTP API) ───────────────────────────────────────────────
# When unset, lib/outboundEmail.ts degrades to a logged noop.
# Replit Mail (used only for invite emails in lib/email.ts) requires no env.
RESEND_API_KEY=re_...
EMAIL_FROM=notifications@example.com

# ── Replit Object Storage (file uploads, GCS-backed) ──────────────────────
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=
OBJECT_STORAGE_HEALTH_TIMEOUT_MS=
# REPLIT_CONNECTORS_HOSTNAME is auto-provided by Replit.
REPLIT_CONNECTORS_HOSTNAME=

# ── Notification scheduler (in-process + external cron) ───────────────────
# Bearer token required by GET|POST /api/cron/notifications-sweep.
# Refuses to run if unset.
CRON_SECRET=
# Override the in-process 15-min interval. Set to "1" to disable in-process scheduler.
NOTIFICATIONS_SWEEP_INTERVAL_MS=
NOTIFICATIONS_SWEEP_DISABLED=

# ── Smoke / test helpers (optional) ───────────────────────────────────────
SMOKE_ADMIN_ID=
SMOKE_ORIGIN=
